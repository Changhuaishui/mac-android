#!/bin/bash
# Fallback wrapper: uses locally cached Gradle 9.3.0 when wrapper jar is unavailable.
set -e
GRADLE_HOME="/Users/chenji/.gradle/wrapper/dists/gradle-9.3.0-bin/79n14ral3mx1ozqr3csh2u872/gradle-9.3.0"
if [ -x "$GRADLE_HOME/bin/gradle" ]; then
    exec "$GRADLE_HOME/bin/gradle" "$@"
else
    echo "Cached Gradle not found at $GRADLE_HOME/bin/gradle" >&2
    echo "Please run 'gradle wrapper' in this directory first." >&2
    exit 1
fi
