<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/hostInput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="#CC000000"
        android:hint="@string/hint_host"
        android:importantForAutofill="no"
        android:inputType="textUri"
        android:minWidth="160dp"
        android:padding="8dp"
        android:text="@string/default_host"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:textSize="14sp" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/portInput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="192dp"
        android:layout_marginTop="16dp"
        android:background="#CC000000"
        android:hint="@string/hint_port"
        android:importantForAutofill="no"
        android:inputType="number"
        android:minWidth="80dp"
        android:padding="8dp"
        android:text="@string/default_port"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:textSize="14sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/connectButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="288dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#3D5AFE"
        android:minWidth="80dp"
        android:text="@string/btn_connect"
        android:textColor="#FFFFFF" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/disconnectButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="376dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#B00020"
        android:minWidth="80dp"
        android:text="@string/btn_disconnect"
        android:textColor="#FFFFFF"
        android:visibility="gone" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/playAssetButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="472dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#008577"
        android:minWidth="120dp"
        android:text="@string/btn_play_asset"
        android:textColor="#FFFFFF" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/stopAssetButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="604dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#B00020"
        android:minWidth="120dp"
        android:text="@string/btn_stop_asset"
        android:textColor="#FFFFFF"
        android:visibility="gone" />

    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="#CC000000"
        android:padding="8dp"
        android:text="@string/status_disconnected"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/capabilityText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="16dp"
        android:background="#CC000000"
        android:padding="8dp"
        android:text="@string/capability_loading"
        android:textColor="#00E676"
        android:textSize="12sp"
        android:visibility="visible" />

    <TextView
        android:id="@+id/modeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="96dp"
        android:layout_marginEnd="16dp"
        android:background="#CC000000"
        android:padding="8dp"
        android:text="@string/mode_mirror"
        android:textColor="#FFD600"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="visible" />

    <TextView
        android:id="@+id/statsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:background="#CC000000"
        android:padding="8dp"
        android:text="FPS: 0 | 0 ms"
        android:textColor="#00E676"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/errorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#B00020"
        android:padding="16dp"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone" />

</FrameLayout>
